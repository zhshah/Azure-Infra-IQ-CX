import React, { useState, useMemo } from "react";

// ── Constants ──────────────────────────────────────────────────────────────────

const SEV_COLOR = {
  critical: "#ef4444",
  high:     "#f97316",
  medium:   "#eab308",
  low:      "#64748b",
};

const SEV_LABEL = {
  critical: "Critical",
  high:     "High",
  medium:   "Medium",
  low:      "Low",
};

const GAP_TYPE_LABEL = {
  no_backup:         "No Backup",
  short_retention:   "Short Retention",
  ltr_recommended:   "No Long-Term Retention",
  vault_backup_only: "VM Backup Only",
};

const GAP_TYPE_COLOR = {
  no_backup:         "#ef4444",
  short_retention:   "#eab308",
  ltr_recommended:   "#64748b",
  vault_backup_only: "#64748b",
};

const PROTECTION_TYPE_BADGE = {
  vault: { label: "Vault Required",   color: "#f97316" },
  auto:  { label: "Auto-Protected",   color: "#22c55e" },
};

const CATEGORY_ICON = {
  vm:          "🖥️",
  sql_in_vm:   "🗄️",
  aks:         "☸️",
  storage:     "💾",
  sql_db:      "📊",
  sql_mi:      "🏛️",
  postgresql:  "🐘",
  mysql:       "🐬",
};

// ── Hero / summary section ─────────────────────────────────────────────────────

function BackupHero({ coverage }) {
  if (!coverage) return null;

  const { total_eligible, total_protected, coverage_pct, critical_gaps, high_gaps, medium_gaps, low_gaps, total_gaps } = coverage;

  const heroColor =
    critical_gaps > 0 ? "#ef4444"
    : high_gaps > 0   ? "#f97316"
    : medium_gaps > 0 ? "#eab308"
    :                   "#22c55e";

  const heroLabel =
    critical_gaps > 0 ? "Immediate Action Required"
    : high_gaps > 0   ? "High Priority Gaps Found"
    : medium_gaps > 0 ? "Review Recommended"
    :                   "Good Coverage";

  // Donut-like arc using a simple circle
  const pct     = Math.min(100, Math.max(0, coverage_pct));
  const radius  = 44;
  const circ    = 2 * Math.PI * radius;
  const dash    = (pct / 100) * circ;
  const arcColor = pct >= 80 ? "#22c55e" : pct >= 60 ? "#eab308" : "#ef4444";

  return (
    <div
      style={{
        background: "#0f172a",
        border: `1px solid ${heroColor}25`,
        borderLeft: `4px solid ${heroColor}`,
        borderRadius: 16,
        padding: "24px",
        marginBottom: 24,
      }}
    >
      {/* Title */}
      <div style={{ color: "#64748b", fontSize: 11, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.5px", marginBottom: 16 }}>
        Azure Backup Resilience — Estate Coverage
      </div>

      <div style={{ display: "flex", gap: 24, flexWrap: "wrap", alignItems: "flex-start" }}>
        {/* Coverage ring */}
        <div style={{ display: "flex", flexDirection: "column", alignItems: "center", gap: 4, flexShrink: 0 }}>
          <svg width={110} height={110}>
            <circle cx={55} cy={55} r={radius} fill="none" stroke="#1e293b" strokeWidth={10} />
            <circle
              cx={55} cy={55} r={radius}
              fill="none" stroke={arcColor} strokeWidth={10}
              strokeDasharray={`${dash} ${circ}`}
              strokeLinecap="round"
              transform="rotate(-90 55 55)"
            />
            <text x="50%" y="50%" dominantBaseline="middle" textAnchor="middle" fill={arcColor} fontSize={18} fontWeight={800}>
              {Math.round(pct)}%
            </text>
          </svg>
          <div style={{ color: "#475569", fontSize: 10, fontWeight: 600, textTransform: "uppercase" }}>Coverage</div>
          <div style={{ color: "#94a3b8", fontSize: 11 }}>{total_protected}/{total_eligible} protected</div>
        </div>

        {/* Severity breakdown */}
        <div style={{ flex: 1, minWidth: 200 }}>
          <div style={{ display: "flex", alignItems: "center", gap: 8, marginBottom: 14, flexWrap: "wrap" }}>
            <span style={{ color: "#f1f5f9", fontSize: 26, fontWeight: 800 }}>{total_gaps}</span>
            <span style={{ color: "#475569", fontSize: 14 }}>items need attention</span>
            <span style={{
              background: `${heroColor}15`, color: heroColor,
              fontSize: 11, fontWeight: 700, padding: "2px 10px",
              borderRadius: 20, border: `1px solid ${heroColor}30`,
            }}>
              {heroLabel}
            </span>
          </div>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {[
              { sev: "critical", count: critical_gaps },
              { sev: "high",     count: high_gaps     },
              { sev: "medium",   count: medium_gaps   },
              { sev: "low",      count: low_gaps      },
            ].map(({ sev, count }) => (
              <div
                key={sev}
                style={{
                  background: `${SEV_COLOR[sev]}10`,
                  border: `1px solid ${SEV_COLOR[sev]}25`,
                  borderRadius: 10,
                  padding: "10px 16px",
                  textAlign: "center",
                  minWidth: 70,
                }}
              >
                <div style={{ color: SEV_COLOR[sev], fontSize: 22, fontWeight: 800 }}>{count}</div>
                <div style={{ color: "#64748b", fontSize: 9, fontWeight: 700, textTransform: "uppercase" }}>
                  {SEV_LABEL[sev]}
                </div>
              </div>
            ))}
          </div>

          {/* Explanation */}
          <div style={{ marginTop: 14, color: "#475569", fontSize: 11, lineHeight: 1.6 }}>
            <strong style={{ color: "#94a3b8" }}>Critical/High</strong> = no vault backup (data loss risk) ·&nbsp;
            <strong style={{ color: "#94a3b8" }}>Medium</strong> = short retention (7 days, tier upgrade needed) ·&nbsp;
            <strong style={{ color: "#94a3b8" }}>Low</strong> = auto-protected, Long-Term Retention review recommended
          </div>
        </div>
      </div>
    </div>
  );
}

// ── Category heatmap ───────────────────────────────────────────────────────────

function CategoryHeatmap({ categories = [] }) {
  if (!categories.length) return null;
  return (
    <div
      style={{
        background: "#0f172a",
        border: "1px solid #1e293b",
        borderRadius: 16,
        padding: "20px 24px",
        marginBottom: 24,
      }}
    >
      <div style={{ color: "#64748b", fontSize: 11, fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.5px", marginBottom: 14 }}>
        Coverage by Category
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(180px, 1fr))", gap: 10 }}>
        {categories.map((cat) => {
          const pct   = cat.coverage_pct;
          const color = pct >= 80 ? "#22c55e" : pct >= 50 ? "#eab308" : "#ef4444";
          const ptMeta = PROTECTION_TYPE_BADGE[cat.protection_type] || PROTECTION_TYPE_BADGE.vault;
          return (
            <div
              key={cat.category_key}
              style={{
                background: "#1e293b",
                border: `1px solid ${color}25`,
                borderRadius: 12,
                padding: "12px 14px",
              }}
            >
              <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 6 }}>
                <span style={{ fontSize: 20 }}>{cat.icon || CATEGORY_ICON[cat.category_key] || "📦"}</span>
                <span style={{
                  background: `${ptMeta.color}15`,
                  color: ptMeta.color,
                  fontSize: 8,
                  fontWeight: 700,
                  padding: "1px 5px",
                  borderRadius: 8,
                  textTransform: "uppercase",
                  letterSpacing: "0.3px",
                }}>
                  {ptMeta.label}
                </span>
              </div>
              <div style={{ color: "#e2e8f0", fontSize: 12, fontWeight: 600, marginBottom: 6, lineHeight: 1.3 }}>
                {cat.category}
              </div>
              {/* Progress bar */}
              <div style={{ height: 4, background: "#0f172a", borderRadius: 2, marginBottom: 6, overflow: "hidden" }}>
                <div style={{ height: "100%", width: `${pct}%`, background: `linear-gradient(90deg, ${color}99, ${color})`, borderRadius: 2, transition: "width 0.8s ease" }} />
              </div>
              <div style={{ display: "flex", justifyContent: "space-between", color: "#475569", fontSize: 10 }}>
                <span style={{ color }}>{Math.round(pct)}% covered</span>
                <span>{cat.protected}/{cat.eligible}</span>
              </div>
              {cat.gaps > 0 && (
                <div style={{
                  marginTop: 5,
                  background: `${SEV_COLOR.high}10`,
                  borderRadius: 6,
                  padding: "2px 6px",
                  color: SEV_COLOR.high,
                  fontSize: 10,
                  fontWeight: 600,
                  display: "inline-block",
                }}>
                  {cat.gaps} gap{cat.gaps !== 1 ? "s" : ""}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </div>
  );
}

// ── Individual gap card ────────────────────────────────────────────────────────

function BackupGapCard({ gap }) {
  const [open, setOpen] = useState(false);
  const sevColor  = SEV_COLOR[gap.severity]  || "#64748b";
  const gtColor   = GAP_TYPE_COLOR[gap.gap_type] || "#64748b";
  const icon      = gap.icon || CATEGORY_ICON[gap.backup_category_key] || "📦";

  return (
    <div
      style={{
        background: "#0f172a",
        border: "1px solid #1e293b",
        borderRadius: 12,
        padding: "14px 16px",
        borderLeft: `3px solid ${sevColor}`,
      }}
    >
      <div style={{ display: "flex", alignItems: "flex-start", gap: 10 }}>
        <span style={{ fontSize: 20, flexShrink: 0 }}>{icon}</span>
        <div style={{ flex: 1, minWidth: 0 }}>
          {/* Title row */}
          <div style={{ display: "flex", alignItems: "center", gap: 8, flexWrap: "wrap", marginBottom: 4 }}>
            <span style={{ color: "#f1f5f9", fontWeight: 700, fontSize: 14 }}>{gap.resource_name}</span>
            {/* Severity */}
            <span style={{
              background: `${sevColor}20`, color: sevColor,
              fontSize: 9, fontWeight: 700, padding: "2px 7px",
              borderRadius: 20, border: `1px solid ${sevColor}40`,
              textTransform: "uppercase", letterSpacing: "0.4px",
            }}>
              {SEV_LABEL[gap.severity] || gap.severity}
            </span>
            {/* Gap type */}
            <span style={{
              background: `${gtColor}12`, color: gtColor,
              fontSize: 9, fontWeight: 700, padding: "2px 7px",
              borderRadius: 20, border: `1px solid ${gtColor}30`,
              textTransform: "uppercase", letterSpacing: "0.4px",
            }}>
              {GAP_TYPE_LABEL[gap.gap_type] || gap.gap_type}
            </span>
            {/* Category badge */}
            <span style={{ color: "#475569", fontSize: 10, background: "#1e293b", padding: "2px 7px", borderRadius: 10, border: "1px solid #334155" }}>
              {gap.backup_category}
            </span>
          </div>

          {/* Resource group + type */}
          <div style={{ color: "#475569", fontSize: 10, marginBottom: 6 }}>
            <span>{gap.resource_group}</span>
            <span style={{ color: "#334155", margin: "0 5px" }}>·</span>
            <span>{gap.resource_type}</span>
          </div>

          {/* Description */}
          <div style={{ color: "#94a3b8", fontSize: 12, lineHeight: 1.6, marginBottom: 6 }}>
            {gap.description}
          </div>

          {/* Monthly cost */}
          {gap.estimated_monthly_cost > 0 && (
            <div style={{ color: "#475569", fontSize: 11, marginBottom: 6 }}>
              💰 ${Math.round(gap.estimated_monthly_cost).toLocaleString()}/mo resource cost
            </div>
          )}

          {/* Backup solution pill */}
          <div style={{ marginBottom: 6 }}>
            <span style={{
              background: "#1e40af18", color: "#60a5fa",
              fontSize: 10, fontWeight: 600, padding: "3px 9px",
              borderRadius: 20, border: "1px solid #1d4ed830",
            }}>
              🛡️ {gap.backup_solution}
            </span>
          </div>

          {/* Expand button */}
          <button
            onClick={() => setOpen(!open)}
            style={{ background: "none", border: "none", color: "#475569", cursor: "pointer", fontSize: 10, padding: 0 }}
          >
            {open ? "▲ Hide fix guide" : "▼ Show recommendation & fix guide"}
          </button>

          {open && (
            <div
              style={{
                marginTop: 10,
                background: "#1e293b",
                borderRadius: 8,
                padding: "12px 14px",
                border: "1px solid #334155",
              }}
            >
              <div style={{ color: "#22c55e", fontSize: 11, fontWeight: 600, marginBottom: 6 }}>
                ✅ Recommendation
              </div>
              <div style={{ color: "#94a3b8", fontSize: 12, lineHeight: 1.6, marginBottom: 10 }}>
                {gap.recommendation}
              </div>
              {gap.az_link && (
                <a
                  href={gap.az_link}
                  target="_blank"
                  rel="noopener noreferrer"
                  style={{ color: "#3b82f6", fontSize: 11, textDecoration: "none" }}
                >
                  📖 Microsoft Docs — {gap.backup_solution} →
                </a>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

// ── Main export ────────────────────────────────────────────────────────────────

export default function BackupResiliencePanel({ backupCoverage }) {
  const [filterSev,  setFilterSev]  = useState("all");
  const [filterCat,  setFilterCat]  = useState("all");
  const [filterType, setFilterType] = useState("all");   // "vault" | "auto"

  const coverage = backupCoverage;
  const allGaps  = coverage?.gaps ?? [];

  const filteredGaps = useMemo(() => {
    return allGaps.filter((g) => {
      if (filterSev  !== "all" && g.severity              !== filterSev)  return false;
      if (filterCat  !== "all" && g.backup_category_key   !== filterCat)  return false;
      if (filterType !== "all") {
        const meta = coverage?.categories?.find(c => c.category_key === g.backup_category_key);
        if (meta && meta.protection_type !== filterType) return false;
      }
      return true;
    });
  }, [allGaps, filterSev, filterCat, filterType, coverage]);

  const categories  = coverage?.categories ?? [];
  const allCatKeys  = [...new Set(allGaps.map(g => g.backup_category_key))];
  const allCats     = allCatKeys.map(k => ({
    key: k,
    label: allGaps.find(g => g.backup_category_key === k)?.backup_category || k,
  }));

  if (!coverage) {
    return (
      <div style={{
        textAlign: "center", padding: "60px 20px",
        color: "#475569", background: "#0f172a",
        borderRadius: 16, border: "1px solid #1e293b",
      }}>
        <div style={{ fontSize: 40, marginBottom: 12 }}>🔄</div>
        <div style={{ fontSize: 15, fontWeight: 600, color: "#94a3b8", marginBottom: 6 }}>
          Backup coverage data not yet available
        </div>
        <div style={{ fontSize: 12 }}>Run a full scan to generate backup resilience analysis.</div>
      </div>
    );
  }

  return (
    <div style={{ fontFamily: "inherit" }}>
      {/* Hero */}
      <BackupHero coverage={coverage} />

      {/* Category heatmap */}
      <CategoryHeatmap categories={categories} />

      {/* Filter bar */}
      <div
        style={{
          display: "flex",
          gap: 8,
          flexWrap: "wrap",
          marginBottom: 16,
          padding: "12px 16px",
          background: "#0f172a",
          border: "1px solid #1e293b",
          borderRadius: 12,
        }}
      >
        {/* Severity filter */}
        <div style={{ display: "flex", gap: 4, alignItems: "center", flexWrap: "wrap" }}>
          <span style={{ color: "#475569", fontSize: 10, fontWeight: 700, textTransform: "uppercase", marginRight: 4 }}>Severity:</span>
          {[["all", "All", "#64748b"], ["critical", "Critical", "#ef4444"], ["high", "High", "#f97316"], ["medium", "Medium", "#eab308"], ["low", "Low", "#64748b"]].map(([val, lbl, col]) => (
            <button
              key={val}
              onClick={() => setFilterSev(val)}
              style={{
                background: filterSev === val ? `${col}20` : "transparent",
                border: `1px solid ${filterSev === val ? col : "#334155"}`,
                color: filterSev === val ? col : "#64748b",
                borderRadius: 20, padding: "2px 10px", fontSize: 11,
                cursor: "pointer", fontWeight: filterSev === val ? 700 : 500,
              }}
            >
              {lbl}{val !== "all" ? ` (${allGaps.filter(g => g.severity === val).length})` : ""}
            </button>
          ))}
        </div>

        {/* Protection type filter */}
        <div style={{ display: "flex", gap: 4, alignItems: "center", flexWrap: "wrap", borderLeft: "1px solid #1e293b", paddingLeft: 10 }}>
          <span style={{ color: "#475569", fontSize: 10, fontWeight: 700, textTransform: "uppercase", marginRight: 4 }}>Type:</span>
          {[["all", "All"], ["vault", "Vault Required"], ["auto", "Auto-Protected"]].map(([val, lbl]) => (
            <button
              key={val}
              onClick={() => setFilterType(val)}
              style={{
                background: filterType === val ? "#3b82f620" : "transparent",
                border: `1px solid ${filterType === val ? "#3b82f6" : "#334155"}`,
                color: filterType === val ? "#60a5fa" : "#64748b",
                borderRadius: 20, padding: "2px 10px", fontSize: 11,
                cursor: "pointer", fontWeight: filterType === val ? 700 : 500,
              }}
            >
              {lbl}
            </button>
          ))}
        </div>
      </div>

      {/* Results count */}
      <div style={{ color: "#475569", fontSize: 11, marginBottom: 12 }}>
        Showing {filteredGaps.length} of {allGaps.length} items
      </div>

      {/* Gap cards */}
      {filteredGaps.length === 0 ? (
        <div style={{
          textAlign: "center", padding: "40px 20px",
          color: "#475569", background: "#0f172a",
          borderRadius: 12, border: "1px solid #1e293b",
        }}>
          <div style={{ fontSize: 32, marginBottom: 10 }}>✅</div>
          <div style={{ fontSize: 14, fontWeight: 600, color: "#94a3b8" }}>
            No items match the current filter
          </div>
        </div>
      ) : (
        <div style={{ display: "flex", flexDirection: "column", gap: 10 }}>
          {filteredGaps.map((g, i) => (
            <BackupGapCard key={g.resource_id + i} gap={g} />
          ))}
        </div>
      )}
    </div>
  );
}
